    "    \"args\" : [{\"kernel_size\" : 4} , {\"kernel_size\" : 2}],\n",
    "    \"hidden_act\" : nn.ReLU,\n",
    "    \"out_act\" : nn.Sigmoid,\n",
    "    \"weight_init\" : \"uniform\"\n",
    "}\n",
    "\n",
    "net = Network(arch_params = [cnn_arch])\n",
    "print(net)\n",
    "print(\"----------\")\n",
    "print(f\"inp shape : {t.shape}\")\n",
    "print(f\"out shpae : {net(t).shape}\")"

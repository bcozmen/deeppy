   "source": [
    "### You can also create your own layers\n",
    "\n",
    "Let's convert the dense layer output back to an image"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "id": "471fb122-46b4-4f01-9ae2-ecee498fdbc5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Network(\n",
      "  (criterion): MSELoss()\n",
      "  (model): Sequential(\n",
      "    (0): Conv2d(3, 64, kernel_size=(4, 4), stride=(1, 1))\n",
      "    (1): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n",
      "    (2): ReLU()\n",
      "    (3): Conv2d(64, 32, kernel_size=(4, 4), stride=(1, 1))\n",
      "    (4): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n",
      "    (5): ReLU()\n",
      "    (6): Conv2d(32, 16, kernel_size=(4, 4), stride=(1, 1))\n",
      "    (7): MaxPool2d(kernel_size=2, stride=2, padding=0, dilation=1, ceil_mode=False)\n",
      "    (8): Sigmoid()\n",
      "    (9): Flatten(start_dim=1, end_dim=-1)\n",
      "    (10): Linear(in_features=6256, out_features=128, bias=True)\n",
      "    (11): ReLU()\n",
      "    (12): Linear(in_features=128, out_features=32, bias=True)\n",
      "    (13): ReLU()\n",
      "    (14): Linear(in_features=32, out_features=6256, bias=True)\n",
      "    (15): Identity()\n",
      "    (16): Image()\n",
      "  )\n",
      ")\n",
      "----------\n",
      "inp shape : torch.Size([2, 3, 160, 210])\n",
      "out shpae : torch.Size([2, 16, 17, 23])\n"
     ]
    }
   ],
   "source": [
    "class Image(nn.Module):\n",
    "    def __init__(self, shape = (16,17,23)):\n",
    "        super(Image, self).__init__()\n",
    "        self.shape = shape\n",
    "\n",
    "    def forward(self, x):\n",
    "        return x.view((-1, *self.shape))\n",
    "\n",
    "\n",
    "image_arch = {\n",
    "    \"type\" : Image,\n",
    "    \"args\" : [{\"shape\" : (16,17,23)}]\n",
    "}\n",
    "network_params = [cnn_arch, flatten_arch, dense_arch, image_arch]\n",
    "net = Network(arch_params = network_params)\n",
    "print(net)\n",
    "print(\"----------\")\n",
    "print(f\"inp shape : {t.shape}\")\n",
    "print(f\"out shpae : {net(t).shape}\")"
   ]
  },
